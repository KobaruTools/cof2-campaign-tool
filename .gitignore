# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# règles CO2 — les PDF ne doivent jamais entrer dans git ni dans le bundle…
*.pdf
# …EXCEPTION ciblée (milestone « Visualiseur PDF », app strictement privée) : les
# PDF libres/non-propriété de BBE (livre de base, feuille de perso, écran MJ) sont
# servis par l'app et commités via Git LFS depuis public/pdf/. Cf. .gitattributes et
# le ticket PER-57 (revenir à un import local si l'app est un jour distribuée).
!/public/pdf/*.pdf
# PDF payants/sous copyright (bestiaire, atlas, Le Compagnon) : consultés en local
# uniquement, JAMAIS commités. Le dossier reste hors du repo pour raisons de droits.
/pdf-payants/

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
# …sauf le gabarit d'exemple, qui DOIT être versionné (sans secrets).
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# pages PDF rendues pour lecture par Claude
/.pdf-pages/
.vercel
