# Supabase — socle multi-tenant (PER-187)
# Copier vers `.env.local` et remplir avec les valeurs du projet Supabase
# (Dashboard → Project Settings → API). Ne JAMAIS committer `.env.local`.

# URL du projet + clé anonyme publique : exposées au navigateur (préfixe NEXT_PUBLIC_).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Clé service : SERVEUR UNIQUEMENT, contourne la RLS. Ne jamais préfixer NEXT_PUBLIC_,
# ne jamais l'exposer côté client. Utilisée plus tard (échange de lien magique, PER-191).
SUPABASE_SERVICE_ROLE_KEY=
