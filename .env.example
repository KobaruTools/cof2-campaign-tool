# Supabase — socle multi-tenant (PER-187)
# Copier vers `.env.local` et remplir avec les valeurs du projet Supabase
# (Dashboard → Project Settings → API Keys). Ne JAMAIS committer `.env.local`.
#
# Nomenclature Supabase 2025 : clé « publishable » (sb_publishable_…, ex-anon) et
# clé « secret » (sb_secret_…, ex-service_role). Les anciennes clés anon/service_role
# (JWT) restent acceptées en legacy mais ne sont plus la voie recommandée.

# URL du projet + clé publishable : exposées au navigateur (préfixe NEXT_PUBLIC_).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Clé secrète : SERVEUR UNIQUEMENT, contourne la RLS. Ne jamais préfixer NEXT_PUBLIC_,
# ne jamais l'exposer côté client. Utilisée plus tard (échange de lien magique, PER-191).
SUPABASE_SECRET_KEY=
